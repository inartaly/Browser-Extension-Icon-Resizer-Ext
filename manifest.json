{
  "manifest_version": 3,
  "name": "Browser Extension Icon Resizer",
  "version": "1.6",
  "permissions": ["sidePanel"],
  "host_permissions": [
    "https://inartaly.github.io/Browser-Extension-Icon-Resizer/*"
  ],
  "action": {
    "default_title": "Open Browser Extension Icon Resizer",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
